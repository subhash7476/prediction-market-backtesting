209-209-10-83.sslip.io {
    encode gzip

    # Serve mirrored raw parquet straight from disk so large backfill downloads
    # do not tie up the Python API process.
    handle_path /v1/raw/* {
        root * /srv/pmxt-relay/raw
        header Cache-Control "public, max-age=31536000, immutable"
        file_server
    }

    reverse_proxy 127.0.0.1:8080
}
